# These plugins are lacking license information and marked as “unfree”.
# These plugins are typically old and not updated for years so it’s unlikely
# that the situation changes.
#
# In this attrset:
# - Name is package name
# - Value is a key of `nixpkgs.vimPlugins`
{
  vim-indexed-search = "vim-indexed-search"; # https://github.com/henrik/vim-indexed-search
  delimitMate = "delimitMate"; # https://github.com/raimondi/delimitMate
  vim-hoogle = "vim-hoogle"; # https://github.com/twinside/vim-hoogle
  "rainbow_parentheses.vim" = "rainbow_parentheses-vim"; # https://github.com/kien/rainbow_parentheses.vim
  vim-pug = "vim-pug"; # https://github.com/digitaltoad/vim-pug
  vim-janah = "vim-janah"; # https://github.com/mhinz/vim-janah
}
